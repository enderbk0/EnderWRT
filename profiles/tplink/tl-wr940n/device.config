#
# EnderWRT Target Configuration for TP-Link TL-WR940N v6
# Ultra-Aggressive 4MB Flash / 32MB RAM Optimization Profile (ath79/tiny)
#

# Target Platform
CONFIG_TARGET_ath79=y
CONFIG_TARGET_ath79_tiny=y
CONFIG_TARGET_ath79_tiny_DEVICE_tplink_tl-wr940n-v6=y

# 1. Ultra-Aggressive Kernel Footprint Reduction
CONFIG_KERNEL_PRINTK=n
CONFIG_KERNEL_BUG=n
CONFIG_KERNEL_FHANDLE=n
CONFIG_KERNEL_AIO=n
CONFIG_KERNEL_SYSVIPC=n
CONFIG_KERNEL_MIPS_FPU_EMULATOR=n
CONFIG_KERNEL_ELF_CORE=n
CONFIG_KERNEL_COREDUMP=n

# 2. Binary Stripping and Size Optimizations
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
CONFIG_DEBUG_INFO=n

# 3. Explicitly Disable Package Manager (Saves ~150KB)
CONFIG_PACKAGE_opkg=n
CONFIG_PACKAGE_luci-app-opkg=n

# 4. Explicitly Disable PPP/PPPoE WAN Drivers (Saves ~180KB)
CONFIG_PACKAGE_ppp=n
CONFIG_PACKAGE_ppp-mod-pppoe=n
CONFIG_PACKAGE_kmod-ppp=n
CONFIG_PACKAGE_luci-proto-ppp=n

# 5. Explicitly Disable IPv6 globally (Saves ~350KB)
CONFIG_IPV6=n
CONFIG_PACKAGE_kmod-ipv6=n
CONFIG_PACKAGE_libip6tc=n
CONFIG_PACKAGE_ip6tables=n
CONFIG_PACKAGE_luci-proto-ipv6=n
CONFIG_PACKAGE_odhcpd-ipv6only=n

# 6. Minimal Wireless Drivers
CONFIG_PACKAGE_kmod-ath9k=y
CONFIG_PACKAGE_kmod-ath9k-common=y
CONFIG_PACKAGE_kmod-ath9k-eeprom-otp=y
CONFIG_PACKAGE_ath9k-firmware=y
CONFIG_PACKAGE_wpad-mini=y
CONFIG_PACKAGE_wpad-basic-wolfssl=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n

# 7. Core Services & Networking (DHCP, DNS, Firewall)
CONFIG_PACKAGE_dnsmasq=y
# CONFIG_PACKAGE_dnsmasq_dhcpv6 is not set
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y

# 8. Web Interface Optimizations (English Only, No TLS, No Bootstrap Theme)
CONFIG_PACKAGE_luci=n
CONFIG_PACKAGE_luci-theme-ender=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-theme-bootstrap=n
CONFIG_PACKAGE_uhttpd-mod-tls=n
CONFIG_PACKAGE_px5g=n
CONFIG_PACKAGE_libustream-mbedtls=n
CONFIG_PACKAGE_libustream-openssl=n
CONFIG_PACKAGE_ca-bundle=n
CONFIG_PACKAGE_ca-certificates=n
CONFIG_PACKAGE_uclient-fetch=n
CONFIG_PACKAGE_libuclient=n

# 9. Hardware/Driver Exclusions (No USB, No Storage)
CONFIG_USB_SUPPORT=n
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb2=n
CONFIG_PACKAGE_kmod-usb-ehci=n

# 10. BusyBox Ultra-Minimal Settings
CONFIG_BUSYBOX_CUSTOM=y
# CONFIG_BUSYBOX_CONFIG_FEATURE_IPV6 is not set
# CONFIG_BUSYBOX_CONFIG_UDHCPC6 is not set
# CONFIG_BUSYBOX_CONFIG_FTPD is not set
# CONFIG_BUSYBOX_CONFIG_TFTPD is not set
# CONFIG_BUSYBOX_CONFIG_TELNETD is not set

# 11. Optional VPN/Network Extras (Explicitly disabled)
CONFIG_PACKAGE_luci-proto-wireguard=n
CONFIG_PACKAGE_wireguard-tools=n
CONFIG_PACKAGE_luci-app-openvpn=n
CONFIG_PACKAGE_samba4-server=n
CONFIG_PACKAGE_sqm-scripts=n
CONFIG_PACKAGE_docker=n
