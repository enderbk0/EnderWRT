#
# EnderWRT Target Configuration for TP-Link TL-WR940N v6
# Ultra-Aggressive 4MB Flash / 32MB RAM Optimization Profile (ath79/tiny)
#

# Target Platform
CONFIG_TARGET_ath79=y
CONFIG_TARGET_ath79_tiny=y
CONFIG_TARGET_ath79_tiny_DEVICE_tplink_tl-wr940n-v6=y

# 1. Ultra-Aggressive Kernel Footprint Reduction
# CONFIG_KERNEL_PRINTK is not set (Disables dmesg logs, saves ~100KB)
CONFIG_KERNEL_MIPS_FPU_EMULATOR=n
CONFIG_KERNEL_ELF_CORE=n
CONFIG_KERNEL_COREDUMP=n
# CONFIG_KERNEL_KALLSYMS is not set
# CONFIG_KERNEL_SWAP is not set
# CONFIG_KERNEL_AIO is not set
# CONFIG_KERNEL_SYSVIPC is not set
# CONFIG_KERNEL_FHANDLE is not set
# CONFIG_KERNEL_BUG is not set

# 2. Complete Compiler Stripping & Optimizations
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_STRIP=y
CONFIG_USE_SSTRIP=y
CONFIG_DEBUG_INFO=n

# 3. Disable Package Manager (Saves ~150KB)
# CONFIG_PACKAGE_opkg is not set
# CONFIG_PACKAGE_luci-app-opkg is not set

# 4. Disable PPP/PPPoE WAN Drivers (Saves ~180KB)
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_kmod-ppp is not set
# CONFIG_PACKAGE_luci-proto-ppp is not set

# 5. Global IPv6 Removal (Saves ~350KB)
# CONFIG_IPV6 is not set
# CONFIG_PACKAGE_kmod-ipv6 is not set
# CONFIG_PACKAGE_libip6tc is not set
# CONFIG_PACKAGE_ip6tables is not set
# CONFIG_PACKAGE_luci-proto-ipv6 is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set

# 6. Minimal Wireless Drivers
CONFIG_PACKAGE_kmod-ath9k=y
CONFIG_PACKAGE_kmod-ath9k-common=y
CONFIG_PACKAGE_kmod-ath9k-eeprom-otp=y
CONFIG_PACKAGE_ath9k-firmware=y
CONFIG_PACKAGE_wpad-mini=y
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set

# 7. Core Services & Networking (DHCP, DNS, Firewall)
CONFIG_PACKAGE_dnsmasq=y
# CONFIG_PACKAGE_dnsmasq_dhcpv6 is not set
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y

# 8. Web Interface Optimizations (English Only, No TLS)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-theme-ender=y
CONFIG_PACKAGE_luci-light=y
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
# CONFIG_PACKAGE_libustream-mbedtls is not set
# CONFIG_PACKAGE_libustream-openssl is not set
# CONFIG_PACKAGE_ca-bundle is not set

# 9. Hardware/Driver Exclusions (No USB, No Storage)
# CONFIG_USB_SUPPORT is not set
# CONFIG_PACKAGE_kmod-usb-core is not set

# 10. BusyBox Ultra-Minimal Settings
CONFIG_BUSYBOX_CUSTOM=y
# CONFIG_BUSYBOX_CONFIG_FEATURE_IPV6 is not set
# CONFIG_BUSYBOX_CONFIG_UDHCPC6 is not set
# CONFIG_BUSYBOX_CONFIG_FTPD is not set
# CONFIG_BUSYBOX_CONFIG_TFTPD is not set
# CONFIG_BUSYBOX_CONFIG_TELNETD is not set
# CONFIG_BUSYBOX_CONFIG_IP is not set (Use tiny BusyBox ip commands)

# 11. Optional VPN/Network Extras (Disabled by default)
# CONFIG_PACKAGE_luci-proto-wireguard is not set
# CONFIG_PACKAGE_wireguard-tools is not set
# CONFIG_PACKAGE_luci-app-openvpn is not set
# CONFIG_PACKAGE_samba4-server is not set
# CONFIG_PACKAGE_sqm-scripts is not set
# CONFIG_PACKAGE_docker is not set
